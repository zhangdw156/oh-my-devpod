#!/usr/bin/env bash
set -euo pipefail

prefix="${OPENPOD_PREFIX:-${HOME}/.local/claudepod}"

if [[ -f "${prefix}/env.sh" ]]; then
  # shellcheck disable=SC1090
  source "${prefix}/env.sh"
fi

if [[ -n "${OPENPOD_CLAUDE_SYNC_BIN:-}" && -x "${OPENPOD_CLAUDE_SYNC_BIN}" ]]; then
  "${OPENPOD_CLAUDE_SYNC_BIN}"
fi

shell_dir="${OPENPOD_PREFIX:-${prefix}}/shell"

if [[ $# -eq 0 ]]; then
  exec env ZDOTDIR="${shell_dir}" zsh -i
else
  exec env ZDOTDIR="${shell_dir}" zsh "$@"
fi
